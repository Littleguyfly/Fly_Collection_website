---
// src/layouts/Layout.astro
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Photography Portfolio" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    </head>
	<body>
        <!-- Global Header & Navigation -->
    <header class="site-header">
        <div class="header-texture"></div> <!-- This holds the subtle animal print/jungle texture -->
    
        <div class="header-content">
            <div class="logo">
                <a href="/">
                    <img src="./The.png" alt="Fly Collection Logo" class="logo-img" />
                    <span class="logo-text">The Fly Collection</span>
                </a>
            </div>
            <nav class="site-nav">
                <a href="/">Home</a>
                <a href="/gallery">Gallery</a>
                <a href="/recent">Recent Trips</a>
            </nav>
        </header>
        <div class="construction-banner">
            🚧 Pardon our dust! I am currently migrating my photos to the new site. Check back frequently for new galleries! 🚧
        </div>

        <!-- Page Content is Injected Here -->
		<main>
			<slot />
		</main>

        <!-- Global Footer -->
        <footer class="site-footer">
            <p>&copy; {new Date().getFullYear()} The Fly Collection. All rights reserved.</p>
        </footer>
	</body>
</html>

<style is:global>
    :root {
        /* The New Wildlife Color Palette */
        --bg-color: #f8f8f6;         /* A slightly warmer off-white for the main site */
        --text-color: #1a1a1a;
        --accent-color: #666;
        
        --jungle-dark: #1b2620;      /* Deep, rich forest green/black for the header */
        --savanna-gold: #DDA74F;     /* Warm amber/gold for borders and accents */
        --header-text: #f0f0f0;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Montserrat', sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
        line-height: 1.6;
        display: flex;
        flex-direction: column;
        min-height: 100vh; 
    }
    h1, h2, h3, .logo-text {
        font-family: 'Playfair Display', serif;
    }

    /* =======================================
       THE NEW HEADER STYLING
       ======================================= */
    .site-header {
        position: relative;
        background-color: var(--jungle-dark);
        /* A subtle bottom border to separate it from the page */
        border-bottom: 4px solid var(--savanna-gold);
    }

    /* The Subtle Organic/Animal Pattern */
    .header-texture {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        opacity: 0.05; /* Keeps it VERY subdued. Increase to 0.1 if you want it louder */
        /* This creates a procedural organic pattern that mimics subtle tiger/leopard dappling */
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.015' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        pointer-events: none;
    }

    .header-content {
        position: relative;
        z-index: 1; /* Keeps text above the texture */
        display: flex;
        flex-direction: row; 
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 5%;
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
    }
    
    .construction-banner {
        background-color: var(--savanna-gold);
        color: var(--jungle-dark);
        text-align: center;
        padding: 0.6rem 5%;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        z-index: 10; /* Keeps its shadow above the main content */
        position: relative;
    }

    /* Logo Styling */
    .logo a {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
    }

    .logo-text {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--savanna-gold); /* Makes the text logo pop! */
        letter-spacing: 2px;
    }

    /* If using an image logo */
    .logo-img {
        margin-top: 1rem;
        max-height: 100px;
        width: auto;
    }

    /* Navigation Styling */
    .site-nav { display: flex; gap: 2rem; }
    
    .site-nav a {
        text-decoration: none;
        color: var(--header-text);
        font-weight: 500;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.9rem;
        transition: color 0.3s ease;
    }

    .site-nav a:hover {
        color: var(--savanna-gold);
    }

    /* Main & Footer remain similar */
    main { flex: 1; max-width: 1200px; margin: 0 auto; padding: 2rem 5%; width: 100%; }
    .site-footer { text-align: center; padding: 2rem; font-size: 0.875rem; color: var(--accent-color); }
</style>